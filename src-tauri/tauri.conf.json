{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenWhatsApp",
  "version": "0.1.2",
  "identifier": "com.antoinenz.openwhatsapp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "currentUser"
      }
    }
  }
}
